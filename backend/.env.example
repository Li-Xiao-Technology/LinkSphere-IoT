# LinkSphere Backend 环境变量模板
# 复制此文件为 .env 并填写实际值
# 生产环境严禁使用任何默认值

# 服务端口
PORT=3001

# 必填：JWT 签名密钥（至少 32 位字符）。生产环境必须使用 openssl rand -hex 32 生成
JWT_SECRET=

# 必填：用于设备凭据等敏感字段的对称加密密钥（任意长度）
ENCRYPTION_KEY=

# 数据库（SQLite 默认）
DB_PATH=./data/iot_platform.db
DATABASE_URL="file:./data/iot_platform.db"
# PostgreSQL 生产数据库连接（开发时使用 SQLite 可忽略）
DATABASE_URL_PG=
# 数据库 provider: sqlite | postgresql
DB_PROVIDER=sqlite

# 前端地址（用于 CORS / Socket.io），多个用英文逗号分隔
FRONTEND_URL=http://localhost:3000

# Node 环境
NODE_ENV=development

# API 文档中的服务地址（Swagger UI 使用）
API_BASE_URL=http://localhost:3001/api

# 限流配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000

# 可选：AI 聊天接口配置
AI_API_KEY=
AI_API_URL=

# 可选：初始化管理员密码（仅首次运行 seed.js 时使用）
# 必须至少 8 位字符
INITIAL_ADMIN_PASSWORD=
