{
  "name": "linksphere-backend",
  "version": "1.0.0",
  "description": "LinkSphere Backend Service",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "dev:pg": "cross-env DB_PROVIDER=postgresql DATABASE_URL=$DATABASE_URL_PG nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:pg": "cross-env DB_PROVIDER=postgresql DATABASE_URL=$DATABASE_URL_PG node dist/server.js",
    "db:generate": "prisma generate",
    "db:generate:pg": "prisma generate --schema prisma/schema.postgresql.prisma",
    "db:migrate:pg": "prisma migrate deploy --schema prisma/schema.postgresql.prisma",
    "db:push:pg": "prisma db push --schema prisma/schema.postgresql.prisma",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node seed.js",
    "db:migrate-to-pg": "node migrate-sqlite-to-pg.js"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@types/multer": "^2.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "bcrypt": "^5.1.1",
    "miio": "^0.15.6",
    "cors": "^2.8.6",
    "cron": "^3.1.6",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^8.2.0",
    "jsmodbus": "^4.0.10",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.15.2",
    "multer": "^2.2.0",
    "noble-winrt": "^0.1.1",
    "nodes7": "^0.3.18",
    "pg": "^8.11.3",
    "prisma": "^6.6.0",
    "reflect-metadata": "^0.1.13",
    "socket.io": "^4.7.2",
    "sqlite3": "^5.1.6",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/cron": "^2.4.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.10.9",
    "@types/sqlite3": "^3.1.11",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
